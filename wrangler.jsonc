{
  // Cloudflare Worker serving the Axis site (static HTML in ./public) via Static Assets.
  // Extensionless paths resolve to .html automatically (so /imprint → public/imprint.html).
  //
  // ⚠ "name" MUST match the Worker's name in the Cloudflare dashboard, or the git build fails.
  "name": "axis-website",
  "main": "worker.js",
  "compatibility_date": "2026-06-01",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  }
}
